# Copy to .env and fill in values. Restart `npm run dev` after changes.
# Only VITE_* variables are exposed to the browser (never put secret server keys here).

# Backend API base URL (no trailing slash)
VITE_API_BASE_URL=

# Optional promo video URL on landing page
VITE_INSURANCE_VIDEO_01_URL=

# Optional deploy base path (default /)
# VITE_BASE=/
