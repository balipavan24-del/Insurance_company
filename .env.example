# Copy to .env and fill in values. Restart `npm run dev` after changes.
# Only VITE_* variables are exposed to the browser (never put secret server keys here).
VITE_API_BASE_URL=http://localhost:4591
# Set to true to use backend/server.js; leave unset or false for local fake data in MotorInsurance.jsx (Vercel default)
VITE_USE_MOTOR_POLICY_API=false